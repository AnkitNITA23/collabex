# ─────────────────────────────────────────────────────────────────────────────
# CollabEx Server — Environment Variables Template
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get a free URI from https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
#
# If left empty, the server falls back to local JSON-file storage (data/rooms.json)
MONGODB_URI=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Defaults to * (all) when not set — restrict this in production.
# Example: https://your-app.vercel.app,https://your-app.netlify.app
CLIENT_ORIGIN=
